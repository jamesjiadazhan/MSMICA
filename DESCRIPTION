Package: MSMICA
Type: Package
Title: Mass Spectrometry Metabolite Identification Connection Algorithm (MSMICA)
Version: 1.0.0
Authors@R: c(
    person(given = "Jiada", family = "Zhan", middle = "", "jzha832@emory.edu", role = c("aut", "cre"),
